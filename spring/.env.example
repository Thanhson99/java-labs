# Copy to `spring/.env` when you want Docker Compose and Spring to share local settings.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:15432/usersdb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me

APP_ANALYTICS_DATASOURCE_URL=jdbc:postgresql://localhost:15433/analyticsdb
APP_ANALYTICS_DATASOURCE_USERNAME=postgres
APP_ANALYTICS_DATASOURCE_PASSWORD=change-me

APP_SECURITY_JWT_SECRET=replace-with-32-plus-char-secret

APP_MESSAGING_KAFKA_ENABLED=true
APP_MESSAGING_RABBITMQ_ENABLED=true
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:19092
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest
