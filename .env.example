# Copy this file to `.env` only for local development.
# Do not commit real credentials.

# Spring profile
SPRING_PROFILES_ACTIVE=postgres

# Primary database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:15432/usersdb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me

# Analytics database
APP_ANALYTICS_DATASOURCE_URL=jdbc:postgresql://localhost:15433/analyticsdb
APP_ANALYTICS_DATASOURCE_USERNAME=postgres
APP_ANALYTICS_DATASOURCE_PASSWORD=change-me

# JWT
APP_SECURITY_JWT_SECRET=replace-with-32-plus-char-secret
APP_SECURITY_JWT_EXPIRATION_SECONDS=3600
APP_SECURITY_REFRESH_EXPIRATION_SECONDS=604800

# Kafka
APP_MESSAGING_KAFKA_ENABLED=false
APP_MESSAGING_KAFKA_TOPIC=user-registered.v1
APP_MESSAGING_KAFKA_CONSUMER_GROUP=user-registration-learning
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# RabbitMQ
APP_MESSAGING_RABBITMQ_ENABLED=false
APP_MESSAGING_RABBITMQ_EXCHANGE=user.registration.exchange
APP_MESSAGING_RABBITMQ_QUEUE=user.registration.queue
APP_MESSAGING_RABBITMQ_ROUTING_KEY=user.registered
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest

# Docker Compose defaults
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
